{
  "name": "vars4chat",
  "version": "0.1.0",
  "private": true,
  "description": "Vars4Chat —— SillyTavern 酒馆助手脚本",
  "main": "dist/bundle.js",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --dev",
    "type:check": "tsc --noEmit",
    "lint:check": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
